{
  "database": {
    "rules": "database.rules.json"
  },
  "hosting": {
    "public": "dist/traditional-chinese-class/browser",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "rewrites": [
      {
        "source": "**",
        "destination": "/index.html"
      }
    ]
  },
  "auth": {
    "providers": {}
  }
}
